#!/usr/bin/env bash
# Prepare commit message hook using GitHub Copilot CLI
# If copilot is not available or fails, does nothing and lets user write message manually

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only run for new commits (not amend, merge, etc.)
if [ -n "$COMMIT_SOURCE" ]; then
    exit 0
fi

# Check if there's already a message
if grep -q '^[^#]' "$COMMIT_MSG_FILE"; then
    exit 0
fi

# Check if copilot CLI is available (standalone or via gh)
if command -v copilot &> /dev/null; then
    COPILOT_CMD="copilot"
elif command -v gh &> /dev/null && gh copilot 2>&1 | grep -q "Copilot"; then
    COPILOT_CMD="gh copilot"
else
    # No copilot available, exit gracefully
    exit 0
fi

# Get the diff (limit to 5000 chars to avoid overwhelming the model)
DIFF=$(git diff --cached --no-color | head -c 5000)

if [ -z "$DIFF" ]; then
    exit 0
fi

# Try to generate message with copilot
PROMPT="Generate a concise git commit message for these changes. Use conventional commits format (feat:, fix:, docs:, refactor:, test:, chore:). First line max 72 chars (summary). For commits with disperate changes, add a blank line and detailed body. Be specific.

Changes:
$DIFF"

# Use copilot in non-interactive mode with prompt
AI_MSG=$($COPILOT_CMD --allow-all-tools --model claude-haiku-4.5 -p "$PROMPT" 2>&1 || echo "")

if [ -n "$AI_MSG" ]; then
    # Clean up any markdown code fences or extra text
    AI_MSG=$(echo "$AI_MSG" | sed -n '/^[a-z]*:/,/^$/p' | head -10)

    if [ -n "$AI_MSG" ]; then
        # Prepend AI message to template
        ORIGINAL=$(cat "$COMMIT_MSG_FILE")
        echo "$AI_MSG" > "$COMMIT_MSG_FILE"
        echo "" >> "$COMMIT_MSG_FILE"
        echo "$ORIGINAL" >> "$COMMIT_MSG_FILE"
    fi
fi

exit 0
