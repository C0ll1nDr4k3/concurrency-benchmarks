"""Type stubs for the _nilvec C++ extension module."""

from __future__ import annotations

from typing import Sequence

class SearchResult:
    """Result from a search operation containing IDs and distances."""

    ids: list[int]
    distances: list[float]

    def __repr__(self) -> str: ...

class ConflictStats:
    """Statistics tracking conflicts in concurrent operations."""

    @property
    def insert_attempts(self) -> int: ...
    @property
    def insert_conflicts(self) -> int: ...
    @property
    def search_attempts(self) -> int: ...
    @property
    def search_conflicts(self) -> int: ...
    def insert_conflict_rate(self) -> float: ...
    def search_conflict_rate(self) -> float: ...
    def reset(self) -> None: ...

class FlatVanilla:
    """Flat index with sequential scan."""

    def __init__(self, dim: int) -> None: ...
    def insert(self, data: Sequence[float]) -> int: ...
    def search(self, query: Sequence[float], k: int) -> SearchResult: ...
    def size(self) -> int: ...
    def dim(self) -> int: ...

